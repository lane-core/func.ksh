# await — blocking wait on a Future_t (shift-up ↑P, consuming)
#
# Blocks until the background computation completes, then reads
# the result from the channel into a Result_t. The channel file
# is removed after reading — this enforces linearity (the future
# is consumed exactly once).
#
# Session type dual: ?Result_t.end
#   The parent receives one Result_t from the channel, session ends.
#
# To make a result reusable (!A exponential), cache the Result_t
# after awaiting, or use `memo` on the computation instead of defer.
#
# Reading uses file descriptors (no $() subshell) to preserve
# trailing newlines in values and avoid unnecessary forks.
#
# Usage:
#   Future_t f
#   defer f compute_thing arg1
#   await r f    # blocks until done, r holds the result
#
# After await, the Future_t is reset to empty state (consumed).
# Calling await again on a consumed future is an error.

function await {
    typeset -n _aw_r=$1 _aw_f=$2

    # Already consumed — linearity violation
    if [[ ${_aw_f.status} == empty ]]; then
        _aw_r.err "await: future is empty (already consumed or never deferred)" 1
        return 0
    fi

    # Wait for background process to finish.
    # defer uses disown to suppress job notifications, which makes
    # wait(1) unable to find the PID. Instead, spin on kill -0.
    # In the common case (called after poll confirms completion),
    # the process is already gone and this doesn't loop at all.
    if (( _aw_f.pid > 0 )); then
        while kill -0 ${_aw_f.pid} 2>/dev/null; do
            # Channel is ground truth — break if data arrived,
            # even if PID was reused by an unrelated process.
            [[ -s ${_aw_f.channel} ]] && break
            sleep 0.01
        done
    fi

    # Read result from channel using file descriptors (no subshell fork,
    # preserves trailing newlines that $() would strip).
    if [[ -s ${_aw_f.channel} ]]; then
        typeset header='' body=''
        typeset -i _aw_fd

        exec {_aw_fd}< "${_aw_f.channel}"

        # Line 1: protocol header ("ok" or "err CODE")
        IFS= read -r header <&${_aw_fd}

        # Rest: value or error message (read until EOF)
        IFS= read -rd '' body <&${_aw_fd} || true

        exec {_aw_fd}<&-

        case $header in
            ok)
                _aw_r.ok "$body"
                ;;
            err\ *)
                typeset -i code=${header#err }
                _aw_r.err "$body" "$code"
                ;;
            *)
                _aw_r.err "await: corrupt channel data: ${header}" 1
                ;;
        esac
    else
        _aw_r.err "await: channel empty or missing (process may have been killed)" 1
    fi

    # Consume: remove channel + sidecar files, reset future (linearity)
    rm -f "${_aw_f.channel}" "${_aw_f.channel}.err" 2>/dev/null
    _aw_f.reset

    return 0
}
