# memo — memoize a function's results by input value
#
# Wraps a chain-compatible function with result caching. On first call
# with a given input, executes the function and caches the outcome.
# On subsequent calls with the same input, restores from cache without
# re-executing. Uses printf '%q' encoding for safe cache round-tripping.
#
# The cache key includes the function name, current result state, and
# any extra arguments — so different inputs always get different entries.
# All key fields are printf '%q'-encoded to prevent delimiter collisions.
# Key computation uses printf -v (no subshell) for cache-hit performance.
#
# Usage:
#   chain r memo expensive_fn
#   chain r memo expensive_fn extra_arg
#
# Clear cache with memo_clear (all entries) or memo_clear fn_name.

function memo {
    typeset -n _me_r=$1
    typeset _me_ref=$1 _me_fn=$2
    shift 2

    # Build cache key — printf -v avoids subshell on every lookup
    typeset _me_sep=$'\x1f' _me_qfn _me_qval _me_qextra
    printf -v _me_qfn '%q' "$_me_fn"
    printf -v _me_qextra '%q' "$*"
    typeset _me_key
    if [[ ${_me_r.status} == ok ]]; then
        printf -v _me_qval '%q' "${_me_r.value}"
        _me_key="ok${_me_sep}${_me_qfn}${_me_sep}${_me_qval}${_me_sep}${_me_qextra}"
    else
        typeset _me_qerr _me_qcode
        printf -v _me_qerr '%q' "${_me_r.error}"
        printf -v _me_qcode '%q' "${_me_r.code}"
        _me_key="err${_me_sep}${_me_qfn}${_me_sep}${_me_qerr}${_me_sep}${_me_qcode}${_me_sep}${_me_qextra}"
    fi

    # Cache hit: restore result from encoded entry
    if [[ -n ${_FUNC_KSH_MEMO[$_me_key]+_} ]]; then
        eval set -- "${_FUNC_KSH_MEMO[$_me_key]}"
        if [[ $1 == ok ]]; then
            _me_r.ok "$2"
        else
            _me_r.err "$2" "$3"
        fi
        return 0
    fi

    # Cache miss: execute function
    "$_me_fn" "$_me_ref" "$@"
    typeset -i _me_ret=$?
    if (( _me_ret != 0 )) && [[ ${_me_r.status} == ok ]]; then
        _me_r.err "memo: $_me_fn exited $_me_ret without setting result" $_me_ret
    fi

    # Store result in cache (printf -v avoids subshell here too)
    typeset _me_encoded
    if [[ ${_me_r.status} == ok ]]; then
        printf -v _me_encoded 'ok %q' "${_me_r.value}"
    else
        printf -v _me_encoded 'err %q %q' "${_me_r.error}" "${_me_r.code}"
    fi
    _FUNC_KSH_MEMO[$_me_key]=$_me_encoded

    return 0
}
