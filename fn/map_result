# map_result — transform a Result_t's value without changing its status
#
# If ok, applies the function to .value and stores the output back.
# If err, passes through unchanged. This is fmap for Result_t.
#
# The transform command receives the current value on stdin (via pipe)
# and should print the transformed value to stdout.
#
# Note: the value is piped through `print -r --` (adds a trailing
# newline) and captured via $(...) (strips trailing newlines). This
# is inherent to shell command substitution and means transforms
# that rely on exact trailing whitespace may not round-trip cleanly.
#
# Usage:
#   Result_t r
#   r.ok "HELLO"
#   map_result r tr '[:upper:]' '[:lower:]'
#   # r.value is now "hello"

function map_result {
    typeset -n _map_r=$1
    shift

    [[ ${_map_r.status} == ok ]] || return 0

    typeset _map_out
    _map_out=$(print -r -- "${_map_r.value}" | "$@") || {
        _map_r.err "map_result: transform failed: $*" $?
        return 0
    }
    _map_r.value=$_map_out

    return 0
}
