# p_none_of — parse a character NOT in a set

function p_none_of {
    typeset -n _r=$1 _s=$2
    typeset _chars=$3
    if (( _s.pos >= _s.len )); then
        _r.err "unexpected end of input at position ${_s.pos}" $P_ERR_EOF "${_s.pos}"
        return 0
    fi
    typeset _c=${_s.input:_s.pos:1}
    case $_chars in
        *"$_c"*) _r.err "unexpected '$_c' at position ${_s.pos}" $P_ERR_UNEXP "${_s.pos}" ;;
        *)       (( _s.pos++ )); _r.ok "$_c" ;;
    esac
}
