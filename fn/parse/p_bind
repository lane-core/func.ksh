# p_bind — monadic bind: run parser, pass parsed value to continuation

function p_bind {
    typeset -n _r=$1 _s=$2
    typeset _ref=$1 _sref=$2 _parser=$3 _cont=$4
    shift 4
    "$_parser" "$_ref" "$_sref"
    if [[ ${_r.status} == err ]]; then return 0; fi
    typeset _val=${_r.value}
    "$_cont" "$_ref" "$_sref" "$_val" "$@"
}
