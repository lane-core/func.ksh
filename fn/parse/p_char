# p_char — parse a specific character

function p_char {
    typeset -n _r=$1 _s=$2
    typeset _want=$3
    if (( _s.pos >= _s.len )); then
        _r.err "expected '$_want' at position ${_s.pos}, got end of input" $P_ERR_EOF "${_s.pos}"
        return 0
    fi
    typeset _c=${_s.input:_s.pos:1}
    if [[ $_c == "$_want" ]]; then
        (( _s.pos++ ))
        _r.ok "$_c"
    else
        _r.err "expected '$_want' at position ${_s.pos}, got '$_c'" $P_ERR_EXPECT "${_s.pos}"
    fi
}
