# p_or — deterministic choice: try p1, on failure backtrack and try p2

function p_or {
    typeset -n _r=$1 _s=$2
    typeset _ref=$1 _sref=$2 _p1=$3 _p2=$4
    shift 4
    typeset -i _saved=${_s.pos}
    "$_p1" "$_ref" "$_sref" "$@"
    if [[ ${_r.status} == ok ]]; then return 0; fi
    _s.pos=$_saved
    "$_p2" "$_ref" "$_sref" "$@"
}
