# p_skip_many — zero or more, discard results

function p_skip_many {
    typeset -n _r=$1 _s=$2
    typeset _ref=$1 _sref=$2 _parser=$3
    shift 3
    typeset -i _saved
    while :; do
        _saved=${_s.pos}
        "$_parser" "$_ref" "$_sref" "$@"
        if [[ ${_r.status} == err ]]; then
            _s.pos=$_saved
            break
        fi
    done
    _r.ok ""
}
