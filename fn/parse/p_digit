# p_digit — parse a digit character (inlined predicate)

function p_digit {
    typeset -n _r=$1 _s=$2
    if (( _s.pos >= _s.len )); then
        _r.err "unexpected end of input at position ${_s.pos}" $P_ERR_EOF "${_s.pos}"; return 0
    fi
    typeset _c=${_s.input:_s.pos:1}
    if [[ $_c == [0-9] ]]; then (( _s.pos++ )); _r.ok "$_c"
    else _r.err "unexpected '$_c' at position ${_s.pos}" $P_ERR_UNEXP "${_s.pos}"; fi
}
