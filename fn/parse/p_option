# p_option — optional parser with default value

function p_option {
    typeset -n _r=$1 _s=$2
    typeset _ref=$1 _sref=$2 _parser=$3 _default=$4
    shift 4
    typeset -i _saved=${_s.pos}
    "$_parser" "$_ref" "$_sref" "$@"
    if [[ ${_r.status} == ok ]]; then return 0; fi
    _s.pos=$_saved
    _r.ok "$_default"
}
