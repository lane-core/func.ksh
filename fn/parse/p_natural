# p_natural — natural number: one or more digits, skip trailing whitespace

function p_natural {
    typeset -n _r=$1 _s=$2
    typeset _ref=$1 _sref=$2
    p_many1 "$_ref" "$_sref" p_digit
    if [[ ${_r.status} == err ]]; then return 0; fi
    typeset _val=${_r.value}
    _p_skip_spaces "$_sref"
    _r.ok "$_val"
}
