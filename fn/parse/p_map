# p_map — transform parsed value via shell function

function p_map {
    typeset -n _r=$1 _s=$2
    typeset _ref=$1 _sref=$2 _parser=$3 _fn=$4
    shift 4
    "$_parser" "$_ref" "$_sref"
    if [[ ${_r.status} == err ]]; then return 0; fi
    typeset _val
    _val=$("$_fn" "${_r.value}" "$@")
    _r.ok "$_val"
}
