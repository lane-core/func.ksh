# p_token — apply parser, skip trailing whitespace

function p_token {
    typeset -n _r=$1 _s=$2
    typeset _ref=$1 _sref=$2 _parser=$3
    shift 3
    "$_parser" "$_ref" "$_sref" "$@"
    if [[ ${_r.status} == err ]]; then return 0; fi
    typeset _val=${_r.value}
    _p_skip_spaces "$_sref"
    _r.ok "$_val"
}
