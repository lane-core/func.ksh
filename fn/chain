# chain — sequence a fallible operation through a Result_t
#
# If the result is ok, call the function with the result's variable
# name as its first argument. If the result is err, skip (short-circuit).
# This is monadic bind: (>>=) for Result_t.
#
# Implemented as the ok-arm special case of match (the cut rule):
#   chain r fn  ≡  match r fn -
#
# Usage:
#   Result_t r
#   r.ok "/some/path"
#   chain r validate_path
#   chain r fetch_contents extra_arg
#   # r now holds the outcome of the entire chain
#
# The called function receives the result variable name as $1,
# followed by any extra arguments passed to chain:
#   function my_op {
#       typeset -n _r=$1; shift
#       # ... use ${_r.value} as input, $@ for extra args ...
#       _r.ok "new value"    # on success
#       _r.err "message" 2   # on failure
#   }

function chain {
    match "$1" "$2" - "${@:3}"
}
